# GENDE Backend PHP - Crontab Configuration
# Install: crontab -e  (then paste the lines below)
# Make sure to replace YOUR_API_URL with your actual domain

API_URL=https://api.gende.io

# Send booking reminders every 15 minutes
*/15 * * * * curl -s -X POST "$API_URL/cron/send-reminders" > /dev/null 2>&1

# Process scheduled campaigns every 5 minutes
*/5 * * * * curl -s -X POST "$API_URL/cron/send-campaigns" > /dev/null 2>&1

# Process waitlist every 10 minutes
*/10 * * * * curl -s -X POST "$API_URL/cron/waitlist-process" > /dev/null 2>&1

# Send course reminders every 30 minutes
*/30 * * * * curl -s -X POST "$API_URL/cron/course-reminders" > /dev/null 2>&1

# Timeout inactive conversations every 5 minutes
*/5 * * * * curl -s -X POST "$API_URL/cron/conversation-timeout" > /dev/null 2>&1
