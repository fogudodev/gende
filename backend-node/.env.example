# ============================================
# GENDE Backend - Node.js Configuration
# Copy to .env and fill in your values
# ============================================

# Server
PORT=3001
NODE_ENV=production
APP_URL=https://api.gende.io
FRONTEND_URL=https://app.gende.io

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=gende
DB_USER=gende_user
DB_PASSWORD=your_db_password

# JWT Auth
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET_64_CHARS_MIN
JWT_EXPIRY=3600
REFRESH_EXPIRY=604800

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Evolution API (WhatsApp unofficial)
EVOLUTION_API_URL=https://evolution.seudominio.com
EVOLUTION_API_KEY=your_evolution_api_key

# Meta WhatsApp Business (Official API)
META_WHATSAPP_TOKEN=your_permanent_token
META_WHATSAPP_PHONE_ID=your_phone_id
META_WEBHOOK_VERIFY_TOKEN=gende_verify_2026
META_API_VERSION=v21.0

# Meta App (Instagram + WhatsApp)
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret

# Google Calendar
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# AI (Google Gemini)
GEMINI_API_KEY=your_gemini_api_key
